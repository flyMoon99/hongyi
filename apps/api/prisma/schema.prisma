generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  MALE
  FEMALE
}

enum UserRole {
  ADMIN
  DEPT_MANAGER
  STAFF
}

enum Company {
  HAODING_HONGYI
  STATE_GRID
}

enum InspectionFrequency {
  QUARTERLY
  MONTHLY
  TWICE_MONTHLY
  ANNUALLY
}

enum ExperimentFrequency {
  QUARTERLY
  MONTHLY
}

enum FireInspectionFrequency {
  ANNUALLY
  QUARTERLY
}

enum FireEquipment {
  GAS_SUPPRESSION
  FIRE_EXTINGUISHER
}

model Employee {
  id           String    @id @default(cuid())
  name         String
  gender       Gender    @default(MALE)
  phone        String    @unique
  password     String
  tokenVersion Int       @default(0)
  avatar       String?
  email        String?
  role         UserRole  @default(STAFF)
  company      Company?
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  customerLogs           CustomerLog[]
  inspectionLogs         InspectionLog[]
  experimentLogs         ExperimentLog[]
  employeeLogs           EmployeeLog[]   @relation("target")
  operatedLogs           EmployeeLog[]   @relation("operator")
  responsibleInspections Inspection[]
  responsibleExperiments Experiment[]
  stationRoomLogs        StationRoomLog[]
  fireInspectionLogs     FireInspectionLog[]

  @@map("employees")
}

model EmployeeLog {
  id         String   @id @default(cuid())
  employeeId String
  action     String
  detail     String?
  operatorId String
  createdAt  DateTime @default(now())

  employee Employee @relation("target", fields: [employeeId], references: [id])
  operator Employee @relation("operator", fields: [operatorId], references: [id])

  @@map("employee_logs")
}

model Customer {
  id              String    @id @default(cuid())
  companyName     String
  projectOverview String?
  contactPerson   String
  contactInfo     String
  lastPatrolTime  DateTime?
  company         Company   @default(HAODING_HONGYI)
  isDeleted       Boolean   @default(false)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  inspections Inspection[]
  experiments Experiment[]
  logs        CustomerLog[]

  @@map("customers")
}

model CustomerLog {
  id         String   @id @default(cuid())
  customerId String
  action     String
  detail     String?
  operatorId String
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  operator Employee @relation(fields: [operatorId], references: [id])

  @@map("customer_logs")
}

model Inspection {
  id                  String              @id @default(cuid())
  customerId          String
  responsiblePersonId String
  frequency           InspectionFrequency @default(QUARTERLY)
  powerEquipment      String
  lastInspectionDate  DateTime?
  nextInspectionDate  DateTime?
  safetyTools         String?
  contactPerson       String
  contactInfo         String
  company             Company             @default(HAODING_HONGYI)
  isDeleted           Boolean             @default(false)
  deletedAt           DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  customer          Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  responsiblePerson Employee        @relation(fields: [responsiblePersonId], references: [id])
  logs              InspectionLog[]

  @@map("inspections")
}

model InspectionLog {
  id           String   @id @default(cuid())
  inspectionId String
  action       String
  detail       String?
  operatorId   String
  createdAt    DateTime @default(now())

  inspection Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  operator   Employee   @relation(fields: [operatorId], references: [id])

  @@map("inspection_logs")
}

model Experiment {
  id                  String              @id @default(cuid())
  customerId          String
  responsiblePersonId String
  frequency           ExperimentFrequency @default(QUARTERLY)
  powerEquipment      String
  lastTestDate        DateTime?
  nextTestDate        DateTime?
  safetyTools         String?
  contactPerson       String
  contactInfo         String
  company             Company             @default(HAODING_HONGYI)
  isDeleted           Boolean             @default(false)
  deletedAt           DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  customer          Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  responsiblePerson Employee        @relation(fields: [responsiblePersonId], references: [id])
  logs              ExperimentLog[]

  @@map("experiments")
}

model ExperimentLog {
  id           String   @id @default(cuid())
  experimentId String
  action       String
  detail       String?
  operatorId   String
  createdAt    DateTime @default(now())

  experiment Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  operator   Employee   @relation(fields: [operatorId], references: [id])

  @@map("experiment_logs")
}

model StationRoom {
  id              String    @id @default(cuid())
  name            String
  remark          String?
  contactPerson   String
  contactInfo     String
  company         Company   @default(STATE_GRID)
  isDeleted       Boolean   @default(false)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  fireInspections FireInspection[]
  logs            StationRoomLog[]

  @@map("station_rooms")
}

model StationRoomLog {
  id            String   @id @default(cuid())
  stationRoomId String
  action        String
  detail        String?
  operatorId    String
  createdAt     DateTime @default(now())

  stationRoom StationRoom @relation(fields: [stationRoomId], references: [id], onDelete: Cascade)
  operator    Employee    @relation(fields: [operatorId], references: [id])

  @@map("station_room_logs")
}

model FireInspection {
  id                  String                  @id @default(cuid())
  stationRoomId       String
  frequency           FireInspectionFrequency @default(ANNUALLY)
  responsiblePerson   String
  equipment           FireEquipment[]
  lastInspectionDate  DateTime?
  nextInspectionDate  DateTime?
  remark              String?
  contactPerson       String
  contactInfo         String
  company             Company                 @default(STATE_GRID)
  isDeleted           Boolean                 @default(false)
  deletedAt           DateTime?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  stationRoom StationRoom         @relation(fields: [stationRoomId], references: [id], onDelete: Cascade)
  logs        FireInspectionLog[]

  @@map("fire_inspections")
}

model FireInspectionLog {
  id               String   @id @default(cuid())
  fireInspectionId String
  action           String
  detail           String?
  operatorId       String
  createdAt        DateTime @default(now())

  fireInspection FireInspection @relation(fields: [fireInspectionId], references: [id], onDelete: Cascade)
  operator       Employee       @relation(fields: [operatorId], references: [id])

  @@map("fire_inspection_logs")
}
